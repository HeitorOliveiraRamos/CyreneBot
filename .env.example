# Copy this file to `.env` and fill in your values.
# `.env` is gitignored; `.env.example` is committed as a template.

# --- Required ---
BOT_TOKEN=bot-token
# Default Ollama model (legacy single-pass paths, e.g. /contexto-do-canal).
# MUST be tool-capable. Verified options: llama3.1, llama3.2, qwen2.5, mistral-nemo, granite3-dense.
MODEL_NAME=qwen2.5:14b-instruct-q4_K_M
# Brain pass model (tool routing + factual summary). MUST be tool-capable.
# Defaults to llama3.1 — same as MODEL_NAME until you decide to split them.
BRAIN_MODEL_NAME=qwen2.5:14b-instruct-q4_K_M
# Voice pass model (persona rewrite, no tools). Can be any chat-capable model.
VOICE_MODEL_NAME=qwen2.5:7b-instruct-q4_K_M
# Modelo de VISÃO (opcional): extrai o conteúdo de prints/imagens anexadas (build,
# relíquia, resultado de batalha) como texto antes do pipeline normal. Precisa de um
# modelo vision-capable: `ollama pull qwen2.5vl` (ou llava, llama3.2-vision).
# VAZIO = visão desligada, imagens são ignoradas e o bot responde só ao texto.
VISION_MODEL_NAME=

# --- Database ---
DB_USER=cyrene
DB_PASSWORD=cyrene

# --- Ollama ---
OLLAMA_BASE_URL=http://localhost:11434
# Janela de contexto (tokens). Precisa caber: persona (~3.9k) + histórico da cadeia de
# reply + num_predict (512). O default 4096 truncava o histórico, sobrando só a persona —
# por isso os replies perdiam o contexto. 16384 deixa espaço de sobra pra threads longas.
OLLAMA_NUM_CTX=16384
# Orçamento de tokens da resposta de conhecimento (extração do kit no brain + retelling
# em persona no voice). O num_predict normal (512) serve pra confirmação de moderação,
# mas esmaga um kit completo. Aumente se kits muito longos ainda saírem cortados.
OLLAMA_KNOWLEDGE_NUM_PREDICT=2048

# --- Optional bot tuning ---
# Uncomment and set to override the bundled persona (e.g. file:/etc/cyrene/persona.md).
# Default when UNSET: classpath:prompts/cyrene-personality.md (bundled in the JAR).
# IMPORTANT: leave this LINE COMMENTED OUT if you want the default. Setting it to an
# empty string is treated as "blank" and triggers a fallback warning at startup.
#BOT_PERSONALITY_FILE=
TEST_CHANNEL_ID=

# Busca web (fallback searchWeb) — SearXNG via docker/searxng
SEARXNG_URL=http://localhost:8888
# Quantos dos primeiros resultados a busca abre e LÊ por inteiro (texto da página), em
# vez de só o snippet do SearXNG — é o que torna kits vazados/futuros respondíveis de
# fato. 0 = só snippets. Baixo de propósito (2): melhor ler poucas páginas a fundo do
# que muitas raso (wikis enterram o kit ~14k chars dentro). Snippets ainda vêm de todos.
HSR_WEB_FETCH_PAGES=2
# Limite de caracteres por página injetada no prompt (limita o uso do contexto). Grande
# de propósito: em páginas tipo game8 os multiplicadores só aparecem ~14–16k chars adentro,
# depois do índice/ratings. Reduza se rodar com num_ctx menor.
HSR_WEB_FETCH_CHARS=18000

# --- Base de conhecimento HSR (reindex) ---
# true = na PRÓXIMA inicialização o bot APAGA o vector_store e re-embeda tudo do nanoka,
# gravando a versão indexada em kb_meta. Rode UMA vez e volte pra false. O KbFreshnessCheck
# loga um WARN diário quando sai patch novo (ou enquanto nenhuma versão foi indexada) —
# esse warning é o lembrete de rodar isto.
#   HSR_REINDEX=true java -jar cyrene-bot.jar   (ou mvn spring-boot:run)
HSR_REINDEX=false
# Pinar uma versão específica do nanoka (ex.: 3.4). VAZIO = auto-descoberta da home page.
HSR_NANOKA_VERSION=
