# Copy this file to `.env` and fill in your values.
# `.env` is gitignored; `.env.example` is committed as a template.

# --- Required ---
BOT_TOKEN=your-discord-bot-token-here
MODEL_NAME=llama3

# --- Database ---
DB_USER=cyrene
DB_PASSWORD=cyrene

# --- Ollama ---
OLLAMA_BASE_URL=http://localhost:11434

# --- Optional bot tuning ---
# Override to point at a different persona file (e.g. file:/etc/cyrene/persona.md).
# Default: classpath:prompts/cyrene-personality.md (bundled in the JAR).
BOT_PERSONALITY_FILE=
TEST_CHANNEL_ID=

# --- Moderation (off by default) ---
MODERATION_ENABLED=false
MODERATION_CHANNEL_ID=
