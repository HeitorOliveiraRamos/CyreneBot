# Copy this file to `.env` and fill in your values.
# `.env` is gitignored; `.env.example` is committed as a template.

# --- Required ---
BOT_TOKEN=your-discord-bot-token-here
# Default Ollama model (legacy single-pass paths, e.g. /contexto-do-canal).
# MUST be tool-capable. Verified options: llama3.1, llama3.2, qwen2.5, mistral-nemo, granite3-dense.
MODEL_NAME=llama3.1
# Brain pass model (tool routing + factual summary). MUST be tool-capable.
# Defaults to llama3.1 — same as MODEL_NAME until you decide to split them.
BRAIN_MODEL_NAME=llama3.1
# Voice pass model (persona rewrite, no tools). Can be any chat-capable model.
VOICE_MODEL_NAME=llama3.1

# --- Database ---
DB_USER=cyrene
DB_PASSWORD=cyrene

# --- Ollama ---
OLLAMA_BASE_URL=http://localhost:11434
# Context window (tokens). Must fit: persona (~3.9k tokens) + reply-chain history +
# num_predict (512). The default 4096 is too small — it truncates the history out,
# keeping only the persona, so replies lose their context. Raise for longer threads.
# KV-cache memory grows ~linearly with this value. qwen2.5 supports up to 32k natively.
OLLAMA_NUM_CTX=16384
# Embedding model for the RAG knowledge base. Pull it: `ollama pull nomic-embed-text`.
# Outputs 768-dim vectors — if you change it, change PGVECTOR_DIMS to match.
EMBED_MODEL_NAME=nomic-embed-text

# --- HSR knowledge base (RAG) ---
# Must match the embedding model's output dimension (nomic-embed-text = 768).
PGVECTOR_DIMS=768
# Folder with the Kaggle CSVs to ingest (committed at src/main/resources/hsrdataset).
HSR_DATA_DIR=src/main/resources/hsrdataset
# Set to true for ONE run to (re)build the vector store, then run again without it.
# See SETUP.md. The embeddings live in Postgres, not git — every fresh DB needs this once.
HSR_REINDEX=false
# Web-search fallback (searchWeb tool). Self-hosted SearXNG — see docker/searxng/.
# Leave BLANK to disable web search (lookupHsr still works from local data).
SEARXNG_URL=http://localhost:8888

# --- Optional bot tuning ---
# Uncomment and set to override the bundled persona (e.g. file:/etc/cyrene/persona.md).
# Default when UNSET: classpath:prompts/cyrene-personality.md (bundled in the JAR).
# IMPORTANT: leave this LINE COMMENTED OUT if you want the default. Setting it to an
# empty string is treated as "blank" and triggers a fallback warning at startup.
#BOT_PERSONALITY_FILE=
TEST_CHANNEL_ID=
